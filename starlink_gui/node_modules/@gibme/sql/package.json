{
  "name": "@gibme/sql",
  "version": "22.0.0",
  "description": "Unified TypeScript database abstraction for MySQL, MariaDB, PostgreSQL, and SQLite with connection pooling, transactions, and bulk operations",
  "keywords": [
    "database",
    "sql",
    "mysql",
    "mariadb",
    "postgres",
    "postgresql",
    "sqlite",
    "typescript",
    "orm",
    "query-builder",
    "connection-pool",
    "transactions",
    "bulk-insert",
    "upsert",
    "database-abstraction",
    "sql-wrapper",
    "prepared-statements",
    "multi-database",
    "better-sqlite3",
    "pg",
    "foreign-keys",
    "escaping",
    "crud",
    "node-database",
    "sql-client"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./mysql": "./dist/mysql.js",
    "./mariadb": "./dist/mariadb.js",
    "./postgres": "./dist/postgres.js",
    "./sqlite": "./dist/sqlite.js",
    "./database": "./dist/database.js"
  },
  "typesVersions": {
    "*": {
      "mysql": [
        "./dist/mysql.d.ts"
      ],
      "mariadb": [
        "./dist/mariadb.d.ts"
      ],
      "postgres": [
        "./dist/postgres.d.ts"
      ],
      "sqlite": [
        "./dist/sqlite.d.ts"
      ],
      "database": [
        "./dist/database.d.ts"
      ]
    }
  },
  "files": [
    "dist/*"
  ],
  "license": "MIT",
  "scripts": {
    "build": "yarn build:typescript",
    "build:docs": "./node_modules/.bin/typedoc",
    "build:typescript": "./node_modules/.bin/tsc",
    "test": "yarn test:style && yarn test:typecheck && yarn test:units",
    "test:typecheck": "./node_modules/.bin/tsc --noEmit",
    "test:style": "yarn style",
    "test:units": "node --import tsx --test --test-timeout 1440000 test/test.ts",
    "style": "./node_modules/.bin/eslint src/**/*.ts test/**/*.ts",
    "fix-style": "./node_modules/.bin/eslint --fix src/**/*.ts test/**/*.ts",
    "fix:style": "yarn fix-style",
    "prepublishOnly": "yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gibme-npm/sql.git"
  },
  "bugs": {
    "url": "https://github.com/gibme-npm/sql/issues"
  },
  "homepage": "https://gibme-npm.github.io/sql/",
  "engines": {
    "node": ">=22"
  },
  "engineStrict": true,
  "author": {
    "name": "Brandon Lehmann",
    "email": "brandonlehmann@gmail.com"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.20.0",
    "@types/pg-format": "^1.0.5",
    "@types/sqlstring": "^2.3.2",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.8.0",
    "mariadb": "^3.5.2",
    "pg": "^8.20.0",
    "pg-format": "^1.0.4",
    "sqlstring": "^2.3.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "dotenv": "^17.4.0",
    "eslint": "^10.1.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.4.0",
    "tsx": "^4.19.4",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2"
  }
}
